# Site
NEXT_PUBLIC_SITE_URL=

# Supabase
# Public client values. These are safe to expose to the browser when Supabase RLS is configured correctly.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Email notifications via Resend
# Keep this private. Do not expose it with NEXT_PUBLIC_.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_NOTIFICATION_EMAIL=

# Optional fallback recipient if CONTACT_NOTIFICATION_EMAIL is not set.
SITE_OWNER_EMAIL=

# Not required by the current codebase.
# COINGECKO_API_KEY=
